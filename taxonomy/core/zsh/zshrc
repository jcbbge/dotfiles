# ============================================
# OpenCode Aliases & Functions
# ============================================
alias occonfig='code-wrapper ~/.config/opencode/opencode.json'

opencode() {
    if [[ "$1" == "--build" ]]; then
        shift
        echo "Building opencode from source..."
        (cd ~/opencode/packages/opencode && bun run build -- --single && \
         cp ~/opencode/packages/opencode/dist/opencode-darwin-arm64/bin/opencode ~/.opencode/bin/opencode && \
         xattr -r -d com.apple.quarantine ~/.opencode/bin/opencode 2>/dev/null; \
         codesign --sign - --force ~/.opencode/bin/opencode) && \
        echo "Build complete: $(~/.opencode/bin/opencode --version)" || \
        { echo "Build failed."; return 1; }
        [[ $# -eq 0 ]] && return

    elif [[ "$1" == "--sync" ]]; then
        shift
        echo "🔄 Syncing opencode with upstream..."
        
        # Check for local changes
        local had_changes=0
        if ! git -C ~/opencode diff --quiet HEAD 2>/dev/null; then
            had_changes=1
            echo "📦 Stashing local changes..."
            git -C ~/opencode stash push -m "auto-sync-$(date +%Y%m%d-%H%M%S)" || { echo "Stash failed."; return 1; }
        fi
        
        echo "📥 Fetching upstream..."
        git -C ~/opencode fetch upstream || { 
            echo "Fetch failed."
            [[ $had_changes -eq 1 ]] && git -C ~/opencode stash pop
            return 1 
        }
        
        # Check if we're behind
        local behind=$(git -C ~/opencode rev-list --count HEAD..upstream/dev 2>/dev/null)
        if [[ "$behind" == "0" ]]; then
            echo "✅ Already up to date with upstream/dev"
            [[ $had_changes -eq 1 ]] && echo "📦 Restoring stashed changes..." && git -C ~/opencode stash pop
            return 0
        fi
        
        echo "🔄 Merging upstream/dev ($behind commits ahead)..."
        if ! git -C ~/opencode merge upstream/dev --no-edit; then
            echo "❌ Merge failed. Resolve conflicts in ~/opencode, then run: opencode --build"
            echo "   If stuck: git merge --abort && opencode --sync"
            return 1
        fi
        
        [[ $had_changes -eq 1 ]] && echo "📦 Restoring stashed changes..." && git -C ~/opencode stash pop
        
        echo "🔨 Building..."
        opencode --build || return 1
        
        echo "📤 Pushing to fork..."
        git -C ~/opencode push origin $(git -C ~/opencode branch --show-current) || { echo "Push failed."; return 1; }
        
        echo "✅ Sync complete: $(~/.opencode/bin/opencode --version)"
        [[ $# -eq 0 ]] && return

    elif [[ "$1" == "--update" || "$1" == "--u" ]]; then
        shift
        echo "⚠️  --update is deprecated. Use --sync instead."
        opencode --sync "$@"
        return

    elif [[ "$1" == "--dev" ]]; then
        shift
        echo "Running opencode from source (dev mode)..."
        (cd ~/opencode/packages/opencode && bun run --conditions=browser ./src/index.ts "$@")
        return

    elif [[ "$1" == "--models" ]]; then
        shift
        echo "Refreshing model whitelist..."
        node ~/OpenRouter/openrouter.js --export
        return
    fi

    # Auto-refresh model whitelist if categories file is older than 24h
    local cat_file="$HOME/.config/opencode/openrouter-categories.json"
    if [[ -f "$cat_file" ]]; then
        local age=$(( $(date +%s) - $(stat -f %m "$cat_file") ))
        if (( age > 86400 )); then
            echo "Model whitelist is stale ($(( age / 3600 ))h old), refreshing..."
            node ~/OpenRouter/openrouter.js --export 2>/dev/null &
        fi
    fi

    OPENCODE_DISABLE_AUTOUPDATE=1 ~/.opencode/bin/opencode "$@"
}

# ============================================
# Aider Functions
# ============================================
aider-start() {
    if [[ -n "$VIRTUAL_ENV" ]]; then
        echo "Deactivating current virtual environment..."
        deactivate
    fi

    if [[ ! -d "venv" ]]; then
        echo "Creating new virtual environment..."
        python -m venv venv
    fi

    echo "Activating virtual environment..."
    source venv/bin/activate

    echo "Upgrading pip..."
    pip install --upgrade pip

    if ! pip show aider-chat &> /dev/null; then
        echo "Installing aider..."
        pip install aider-chat
    else
        echo "Upgrading aider..."
        pip install --upgrade aider-chat
    fi

    echo "Starting aider..."
    aider
}

aider-stop() {
    if pgrep -f "aider" > /dev/null; then
        echo "Stopping aider..."
        pkill -f "aider"
        echo "Aider has been stopped."
    else
        echo "No running aider process found."
    fi

    if [[ -n "$VIRTUAL_ENV" ]]; then
        echo "Deactivating virtual environment..."
        deactivate
    fi
}

deactivate-all() {
    if [[ -n "$VIRTUAL_ENV" ]]; then
        echo "Deactivating virtual environment..."
        deactivate
    else
        echo "No active virtual environment found."
    fi
}

