# Start any Laravel project - usage: laravel-start [directory] [port]
laravel-start() {
    local project_dir="${1:-.}"
    local port="${2:-8000}"
    
    # If only a number provided, treat as port for current dir
    if [[ "$1" =~ ^[0-9]+$ ]]; then
        port="$1"
        project_dir="."
    fi
    
    # Resolve to absolute path
    project_dir="$(cd "$project_dir" 2>/dev/null && pwd)" || {
        echo "❌ Cannot find directory: $1"
        return 1
    }
    
    echo "🚀 Starting Laravel project: $project_dir"
    echo "   Port: $port"
    echo ""
    
    cd "$project_dir" || return 1
    
    # Check for artisan
    if [ ! -f "artisan" ]; then
        echo "❌ No artisan found. Is this a Laravel project?"
        return 1
    fi
    
    # Check if server already running
    if lsof -i :$port > /dev/null 2>&1; then
        echo "⚠️  Port $port already in use"
        echo "   App might already be running at http://127.0.0.1:$port"
    else
        echo "🌐 Starting Laravel server..."
        php artisan serve --port=$port > /tmp/laravel-$port.log 2>&1 &
        sleep 2
        if lsof -i :$port > /dev/null 2>&1; then
            echo "✅ Laravel server running on port $port"
        else
            echo "❌ Laravel server failed to start"
            echo "   Check: tail /tmp/laravel-$port.log"
        fi
    fi
    
    # Check/start Vite
    if [ -f "package.json" ]; then
        if ! lsof -i :5173 > /dev/null 2>&1; then
            echo "⚡ Starting Vite..."
            if grep -q "vite" package.json 2>/dev/null; then
                LARAVEL_BYPASS_ENV_CHECK=1 npm run dev > /tmp/vite.log 2>&1 &
                sleep 3
                if lsof -i :5173 > /dev/null 2>&1; then
                    echo "✅ Vite HMR running"
                else
                    echo "⚠️  Vite may need npm install"
                fi
            fi
        else
            echo "✅ Vite already running"
        fi
    fi
    
    echo ""
    echo "📍 URLs:"
    echo "   App:       http://127.0.0.1:$port"
    echo "   Telescope: http://127.0.0.1:$port/telescope (if installed)"
    echo ""
    echo "📋 Commands:"
    echo "   View logs: tail -f storage/logs/laravel.log"
    echo "   Watch:     php artisan pail --timeout=0"
    echo "   Stop:      pkill -f \"php artisan serve\""
    echo ""
    
    # Open browser
    sleep 1
    open "http://127.0.0.1:$port"
}

# Stop all Laravel/Vite processes
laravel-stop() {
    echo "🛑 Stopping all Laravel services..."
    pkill -f "php artisan serve" 2>/dev/null
    pkill -f "vite" 2>/dev/null
    pkill -f "npm run dev" 2>/dev/null
    sleep 1
    echo "✅ All services stopped"
}

# Check status of Laravel services
laravel-status() {
    echo "🔍 Laravel Service Status"
    echo "=========================="
    
    # Check for running Laravel servers
    local laravel_pids=$(pgrep -f "php artisan serve" | wc -l)
    if [ "$laravel_pids" -gt 0 ]; then
        echo "✅ Laravel servers: $laravel_pids running"
        pgrep -f "php artisan serve" | while read pid; do
            local port=$(lsof -P -a -p $pid -i 2>/dev/null | grep TCP | head -1 | grep -o ':[0-9]*' | tr -d ':' | head -1)
            echo "   PID $pid on port ${port:-unknown}"
        done
    else
        echo "❌ No Laravel servers running"
    fi
    
    # Check Vite
    if pgrep -f "vite" > /dev/null; then
        echo "✅ Vite HMR: running"
    else
        echo "❌ Vite HMR: not running"
    fi
    
    echo ""
    echo "📊 Quick Check:"
    curl -s http://127.0.0.1:8000 > /dev/null 2>&1 && echo "   Port 8000: ✅ Responding" || echo "   Port 8000: ❌ No response"
}

