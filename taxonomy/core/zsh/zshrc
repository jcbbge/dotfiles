# ============================================
# Tab Completions
# ============================================
BOOKMARKS_FILE="$HOME/.project-bookmarks"

_get_bookmarks() {
    if [ -f "$BOOKMARKS_FILE" ]; then
        cut -d'=' -f1 "$BOOKMARKS_FILE"
    fi
}

_bookmark_completion() {
    local -a subcmds
    subcmds=('list:list all bookmarks' 'ls:list all bookmarks' 'rm:remove a bookmark' 'edit:edit bookmarks file' 'validate:check if paths exist' 'help:show help')

    if (( CURRENT == 2 )); then
        _alternative \
            'commands:subcommands:_describe "bookmark commands" subcmds' \
            'bookmarks:bookmarks:compadd $(_get_bookmarks)'
    elif (( CURRENT == 3 )) && [[ "${words[2]}" == "rm" ]]; then
        _values 'bookmarks' $(_get_bookmarks)
    fi
}

compdef _bookmark_completion bookmark

_project_completion() {
    local -a projects
    projects=($(_get_bookmarks))
    _arguments '*:project:compadd -a projects'
}

compdef _project_completion code
compdef _project_completion zed

_bookmark_cd_completion() {
    if (( CURRENT == 2 )); then
        local -a projects
        projects=($(_get_bookmarks))
        compadd -a projects
        return
    fi
    _cd
}

compdef _bookmark_cd_completion cd

# ============================================
# Dev Brain: auto-capture terminal commands to SurrealDB thought_stream
# ============================================
function _surreal_preexec() {
  local cmd="$1"
  [[ "$cmd" =~ ^(ls|cd|clear|pwd|surreal|history|cat|echo|man|which|type|grep|find) ]] && return
  local proj
  proj=$(git rev-parse --show-toplevel 2>/dev/null || echo "global")
  local escaped_cmd
  escaped_cmd=$(printf '%s' "$cmd" | python3 -c 'import json,sys; print(json.dumps(sys.stdin.read()))' 2>/dev/null || printf '"%s"' "$cmd")
  local horizon
  horizon=$(date -u -v+4H '+%Y-%m-%dT%H:%M:%SZ' 2>/dev/null || date -u -d '+4 hours' '+%Y-%m-%dT%H:%M:%SZ' 2>/dev/null)
  curl -s -X POST \
    'http://127.0.0.1:8000/key/thought_stream' \
    -H 'Content-Type: application/json' \
    -H 'surreal-ns: dev' \
    -H 'surreal-db: brain' \
    -u 'root:root' \
    -d "{\"type\":\"shell_command\",\"content\":$escaped_cmd,\"project\":\"$proj\",\"tool\":\"zsh\",\"tags\":[],\"frequency\":\"transient\",\"frequency_hz\":1000.0,\"valid_horizon\":\"$horizon\",\"lifecycle_state\":\"active\",\"phase\":0.0}" \
    &>/dev/null & disown
}
autoload -Uz add-zsh-hook
add-zsh-hook preexec _surreal_preexec

