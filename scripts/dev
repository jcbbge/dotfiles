#!/usr/bin/env zsh
# dev — developer environment snapshot
emulate -LR zsh

SERVICES_FILE="${0:A:h}/dev.services"

# ── ANSI ──────────────────────────────────────────────────────────────────────
R='\033[0m'; BOLD='\033[1m'; DIM='\033[2m'
GRN='\033[32m'; RED='\033[31m'; YLW='\033[33m'; CYN='\033[36m'; WHT='\033[97m'

# ── Helpers ───────────────────────────────────────────────────────────────────
_hr()        { printf '%*s' "${1:-$(tput cols)}" '' | tr ' ' '─'; }
_port_live() { lsof -iTCP:"$1" -sTCP:LISTEN -P 2>/dev/null | grep -q LISTEN; }
_pid_on()    { lsof -ti TCP:"$1" -sTCP:LISTEN 2>/dev/null | head -1; }
_mem_mb()    { ps -o rss= -p "$1" 2>/dev/null | awk '{printf "%.0fMB",$1/1024}'; }
_uptime_s()  { ps -o etime= -p "$1" 2>/dev/null | tr -d ' '; }

_health_ms() {
    # _health_ms <url> [timeout_secs]  →  "42ms" or "-"
    local url="$1" timeout="${2:-0.5}"
    local out=$(curl -s -o /dev/null -w '%{http_code} %{time_total}' \
        --connect-timeout "$timeout" --max-time "$timeout" "$url" 2>/dev/null)
    local code="${out%% *}" t="${out##* }"
    [[ "$code" != "000" && -n "$code" ]] \
        && printf '%s' "$t" | awk '{printf "%dms", $1*1000}' \
        || printf '-'
}

_badge() {
    case "$1" in
        UP)      printf "${GRN}●${R} ${GRN}UP${R}     " ;;
        DOWN)    printf "${DIM}○${R} ${DIM}DOWN${R}   " ;;
        SCHED)   printf "${DIM}◷${R} ${DIM}SCHED${R}  " ;;
        CRASHED) printf "${RED}✖${R} ${RED}CRASHED${R}" ;;
    esac
}

_panel_services() {
    local json_file="$1"
    local cols=$(tput cols 2>/dev/null || printf 100)
    printf "${BOLD}${CYN}  CORE SERVICES${R}\n"
    printf "${DIM}  %s${R}\n" "$(_hr $((cols-4)))"
    printf "${DIM}  %-22s %-10s %-8s %-6s %-7s %s${R}\n" NAME STATUS PORT RTT MEM UPTIME
    printf "${DIM}  %s${R}\n" "$(_hr $((cols-4)))"

    local _rows
    _rows=$(python3 - "$json_file" <<'PYEOF'
import json, sys

path = sys.argv[1]
try:
    with open(path) as f:
        data = json.load(f)
except Exception:
    sys.exit(0)

for svc in data.get('services', []):
    name = svc.get('name') or svc.get('label', '')
    state = svc.get('state', 'DOWN')
    port = svc.get('port')
    latency = svc.get('latency_ms')
    mem = svc.get('mem') or '-'
    up = svc.get('uptime') or '-'

    portstr = f":{port}" if port else '-'
    rtt = f"{latency}ms" if isinstance(latency, int) else '-'

    badge = 'DOWN'
    if state == 'UP':
        badge = 'UP'
    elif state == 'CRASHED':
        badge = 'CRASHED'
    elif state == 'SCHED':
        badge = 'SCHED'

    print(f"{name}\t{badge}\t{portstr}\t{rtt}\t{mem}\t{up}")
PYEOF
)
    while IFS=$'\t' read -r name state port rtt mem up; do
        printf '  %-22s ' "$name"
        _badge "$state"
        printf ' %-8s %-6s %-7s %s\n' "$port" "$rtt" "$mem" "$up"
    done <<< "$_rows"
    printf '\n'
}

# ── PORTS — all active TCP listeners ─────────────────────────────────────────
_panel_ports() {
    local json_file="$1"
    local cols=$(tput cols 2>/dev/null || printf 100)
    printf "${BOLD}${CYN}  OPEN PORTS${R}\n"
    printf "${DIM}  %s${R}\n" "$(_hr $((cols-4)))"
    printf "${DIM}  %-7s %-18s %-8s %s${R}\n" PORT PROCESS PID NOTE
    printf "${DIM}  %s${R}\n" "$(_hr $((cols-4)))"

    local _rows
    _rows=$(python3 - "$json_file" <<'PYEOF'
import json, sys
path = sys.argv[1]
try:
    with open(path) as f:
        data = json.load(f)
except Exception:
    sys.exit(0)

for p in sorted(data.get('ports', []), key=lambda x: x.get('port', 0)):
    port = p.get('port')
    proc = p.get('process')
    pid = p.get('pid')
    note = p.get('note') or ''
    print(f"{port}\t{proc}\t{pid}\t{note}")
PYEOF
)
    while IFS=$'\t' read -r port proc pid note; do
        if [[ -n "$note" ]]; then
            printf "  ${WHT}%-7s${R} %-18s %-8s ${DIM}%s${R}\n" ":$port" "$proc" "$pid" "$note"
        else
            printf "  ${YLW}%-7s${R} %-18s %-8s\n" ":$port" "$proc" "$pid"
        fi
    done <<< "$_rows"
    printf '\n'
}

# ── MCP SERVERS + EXECUTOR DEPTH ──────────────────────────────────────────────
_panel_mcp() {
    local json_file="$1"
    local cols=$(tput cols 2>/dev/null || printf 100)
    printf "${BOLD}${CYN}  AGENT IO${R}\n"
    printf "${DIM}  %s${R}\n" "$(_hr $((cols-4)))"

    python3 - "$json_file" <<'PYEOF'
import json, sys

path = sys.argv[1]
try:
    with open(path) as f:
        data = json.load(f)
except Exception:
    sys.exit(0)

mcp = data.get('mcp', [])
if not mcp:
    print("  \033[2mno MCP servers configured\033[0m")
    sys.exit(0)

for entry in mcp:
    name = entry.get('name','')
    t = entry.get('type','?')
    port = entry.get('port')
    state = entry.get('state','DOWN')
    lat = entry.get('latency_ms')

    if state == 'UP':
        badge = '\033[32m● UP\033[0m    '
    elif state == 'CRASHED':
        badge = '\033[31m✖ CRASHED\033[0m'
    elif state == 'SCHED':
        badge = '\033[2m◷ SCHED\033[0m  '
    else:
        badge = '\033[2m○ DOWN\033[0m  '

    port_str = f":{port}" if port else ''
    rtt = f"{lat}ms" if isinstance(lat, int) else '-'

    line = f"  {badge} \033[97m{name:<20}\033[0m"
    if port_str:
        line += f" {port_str:<10} {rtt}"
    elif t == 'stdio':
        cmd = entry.get('command','')
        line += f" stdio {cmd}"
    else:
        line += f" {t}"
    print(line)

    kota = entry.get('kota')
    if kota:
        kp = kota.get('port')
        ks = kota.get('state')
        if kp:
            print(f"  \033[2m  db   ↳\033[0m  :{kp}  {ks}")
PYEOF
    printf '\n'
}

# ── MODELS: MLX ───────────────────────────────────────────────────────────────
_panel_mlx() {
    local hub=~/.cache/huggingface/hub
    [[ ! -d "$hub" ]] && return

    # Find MLX models in HuggingFace cache
    local models=$(find "$hub" -maxdepth 1 -type d -name 'models--*mlx*' 2>/dev/null | sort)
    [[ -z "$models" ]] && return

    local cols=$(tput cols 2>/dev/null || printf 100)
    printf "${BOLD}${CYN}  LOCAL MODELS${R}  ${DIM}mlx${R}\n"
    printf "${DIM}  %s${R}\n" "$(_hr $((cols-4)))"

    printf '%s\n' "$models" | while IFS= read -r dir; do
        [[ -z "$dir" ]] && continue
        local raw=$(basename "$dir")
        # models--org--name -> org/name
        local name=$(printf '%s' "$raw" | sed 's/^models--//; s/--/\//g')
        # Get size of blobs dir (actual model weights)
        local blobs="$dir/blobs"
        local size='-'
        if [[ -d "$blobs" ]]; then
            size=$(du -sh "$blobs" 2>/dev/null | cut -f1)
        fi
        printf "  ${DIM}◈${R}  ${WHT}%-44s${R}  %s\n" "$name" "$size"
    done
    printf '\n'
}

# ── MODELS: WHISPER (Tuna STT) ────────────────────────────────────────────────
_panel_whisper() {
    local base=~/Library/Application\ Support/Tuna/models/whisper
    [[ ! -d "$base" ]] && return

    local cols=$(tput cols 2>/dev/null || printf 100)
    printf "${BOLD}${CYN}  MODELS${R}  ${DIM}whisper · Tuna STT${R}\n"
    printf "${DIM}  %s${R}\n" "$(_hr $((cols-4)))"

    find "$base" -type f -name "*.bin" 2>/dev/null | while read -r f; do
        local model=$(basename "$(dirname "$f")")
        local size=$(du -sh "$f" 2>/dev/null | cut -f1)
        printf "  ${DIM}◈${R}  ${WHT}%-20s${R}  %s\n" "$model" "$size"
    done
    printf '\n'
}

# ── MODELS: APPLE ─────────────────────────────────────────────────────────────
_panel_apple() {
    local cols=$(tput cols 2>/dev/null || printf 100)
    local found=0

    if [[ -d ~/Library/Containers/com.apple.WritingTools.WritingToolsAppIntentsExtension ]]; then
        (( found == 0 )) && {
            printf "${BOLD}${CYN}  MODELS${R}  ${DIM}Apple on-device${R}\n"
            printf "${DIM}  %s${R}\n" "$(_hr $((cols-4)))"
        }
        found=1
        printf "  ${DIM}◈${R}  ${WHT}Apple Intelligence${R}  ${DIM}Writing Tools · Summaries · Replies${R}\n"
    fi

    if [[ -d ~/Library/Containers/com.apple.CoreMotionFoundationModelExtension ]]; then
        (( found == 0 )) && {
            printf "${BOLD}${CYN}  MODELS${R}  ${DIM}Apple on-device${R}\n"
            printf "${DIM}  %s${R}\n" "$(_hr $((cols-4)))"
        }
        found=1
        printf "  ${DIM}◈${R}  ${WHT}Foundation Model${R}     ${DIM}CoreMotion on-device LLM${R}\n"
    fi

    local dictpath=$(find /Library/Application\ Support -maxdepth 3 \
        -name "*.lm" -path "*SpeechRecognition*" 2>/dev/null | head -1)
    if [[ -n "$dictpath" ]]; then
        (( found == 0 )) && {
            printf "${BOLD}${CYN}  MODELS${R}  ${DIM}Apple on-device${R}\n"
            printf "${DIM}  %s${R}\n" "$(_hr $((cols-4)))"
        }
        found=1
        printf "  ${DIM}◈${R}  ${WHT}Enhanced Dictation${R}   ${DIM}on-device speech recognition${R}\n"
    fi

    (( found )) && printf '\n'
}

# ── SYSTEM ────────────────────────────────────────────────────────────────────
_panel_system() {
    local json_file="$1"
    local cols=$(tput cols 2>/dev/null || printf 100)
    printf "${BOLD}${CYN}  SYSTEM HEALTH${R}\n"
    printf "${DIM}  %s${R}\n" "$(_hr $((cols-4)))"

    local _row
    _row=$(python3 - "$json_file" <<'PYEOF'
import json, sys
path = sys.argv[1]
try:
    with open(path) as f:
        data = json.load(f)
except Exception:
    sys.exit(0)

sysinfo = data.get('system', {})
ram_used = sysinfo.get('ram_used_gb')
ram_total = sysinfo.get('ram_total_gb')
disk = sysinfo.get('disk','')
load = sysinfo.get('load_avg','')

ru = f"{ram_used}GB" if isinstance(ram_used, (int,float)) else "?"
rt = f"{ram_total}GB" if isinstance(ram_total, (int,float)) else "?"
print(f"{ru}\t{rt}\t{disk}\t{load}")
PYEOF
)
    IFS=$'\t' read -r ram_used ram_total disk load <<< "$_row"
    printf "  ${DIM}RAM${R}  ${WHT}%s / %s${R}   ${DIM}Disk${R}  ${WHT}%s${R}   ${DIM}Load${R}  ${WHT}%s${R}\n" \
        "$ram_used" "$ram_total" "$disk" "$load"
    printf '\n'
}

# ── STATUS — parallel panels ──────────────────────────────────────────────────
_status() {
    local tdir=$(mktemp -d)
    local jfile="$tdir/snapshot.json"
    _json_output > "$jfile"

    printf "\n${BOLD}${WHT}  ▸ dev${R}  ${DIM}%s · %s${R}\n\n" "$(date '+%Y-%m-%d %H:%M:%S')" "$(hostname -s 2>/dev/null || printf 'host')"

    # Render panels in deterministic order for a clean layout
    _panel_services "$jfile"
    _panel_ports    "$jfile"
    _panel_mcp      "$jfile"
    _panel_mlx
    _panel_whisper
    _panel_apple
    _panel_system   "$jfile"

    rm -rf "$tdir"

    printf "  ${DIM}● up  ○ down  ✖ crashed  ◷ scheduled${R}\n\n"
}

# ── WATCH ─────────────────────────────────────────────────────────────────────
_watch() {
    local interval="${1:-5}"
    trap 'tput cnorm 2>/dev/null; printf "\n"; exit 0' INT TERM
    tput civis 2>/dev/null
    while true; do
        tput clear 2>/dev/null || printf '\033[2J\033[H'
        _status
        printf "  ${DIM}↻ every ${interval}s  ·  ^C exit${R}\n"
        sleep "$interval"
    done
}

# ── LOGS ──────────────────────────────────────────────────────────────────────
_logs() {
    local target="${1:l}"
    [[ -z "$target" ]] && printf "${RED}  usage: dev logs <name>${R}\n" && return 1

    local plist=''
    for p in ~/Library/LaunchAgents/*.plist(N); do
        local label=$(basename "$p" .plist)
        local nick="${label:l}"
        case "${label:l}" in
            com.surrealdb.server) nick=surrealdb ;;
            com.ollama.server)    nick=ollama ;;
        esac
        if [[ "$nick" == "$target" || "${label:l}" == "$target" ]]; then
            plist="$p"; break
        fi
    done

    if [[ -z "$plist" ]]; then
        local row=$(grep -i "^${target}|" "$SERVICES_FILE" 2>/dev/null | head -1)
        if [[ -n "$row" ]]; then
            printf "  ${YLW}%s${R} is a process-type service — no plist log path\n" "$target"
        else
            printf "  ${RED}no service matching: %s${R}\n" "$target"
            printf "  ${DIM}try: surrealdb · ollama · or a full label name${R}\n"
        fi
        return 1
    fi

    local paths=$(python3 - "$plist" <<'PYEOF'
import plistlib, sys
try:
    with open(sys.argv[1], 'rb') as f:
        d = plistlib.load(f)
    print(d.get('StandardOutPath', ''))
    print(d.get('StandardErrorPath', ''))
except:
    print(''); print('')
PYEOF
)
    local stdout_log=$(printf '%s' "$paths" | head -1)
    local stderr_log=$(printf '%s' "$paths" | tail -1)

    local logfile=''
    [[ -n "$stdout_log" && -f "$stdout_log" ]] && logfile="$stdout_log"
    [[ -z "$logfile" && -n "$stderr_log" && -f "$stderr_log" ]] && logfile="$stderr_log"

    if [[ -n "$logfile" ]]; then
        printf "${BOLD}${CYN}  logs:${R} ${WHT}%s${R}  ${DIM}%s${R}\n\n" "$target" "$logfile"
        tail -f "$logfile"
    else
        printf "  ${YLW}no log file configured in plist${R}\n"
        printf "  ${DIM}%s${R}\n" "$plist"
        [[ -n "$stdout_log" ]] && printf "  ${DIM}StandardOutPath: %s (not found)${R}\n" "$stdout_log"
        [[ -n "$stderr_log" ]] && printf "  ${DIM}StandardErrorPath: %s (not found)${R}\n" "$stderr_log"
    fi
}

# ── JSON OUTPUT ───────────────────────────────────────────────────────────────
_json_output() {
    python3 - <<'PYEOF'
import json, subprocess, os, socket, time, re, glob
import urllib.request, urllib.error

def sock_live(port):
    try:
        s = socket.create_connection(('127.0.0.1', int(port)), timeout=0.3)
        s.close(); return True
    except: return False

def http_ms(url, timeout=0.5):
    try:
        start = time.time()
        urllib.request.urlopen(url, timeout=timeout)
        return int((time.time() - start) * 1000)
    except: return None

# PID→port map
lsof_out = subprocess.run(['lsof','-iTCP','-sTCP:LISTEN','-P'],
                          capture_output=True, text=True).stdout
pid_port = {}
for line in lsof_out.splitlines()[1:]:
    parts = line.split()
    if len(parts) >= 9:
        m = re.search(r':(\d+)$', parts[8])
        if m: pid_port[parts[1]] = m.group(1)

lc_out = subprocess.run(['launchctl','list'], capture_output=True, text=True).stdout

# Services
NAME_MAP = {'com.surrealdb.server':'SurrealDB','com.ollama.server':'Ollama','com.belvedere.tts-server':'TTS','com.belvedere.llm-server':'LLM'}
HEALTH_URL = {'6000':'http://127.0.0.1:6000/health','11434':'http://127.0.0.1:11434/','7010':'http://127.0.0.1:7010/','7200':'http://127.0.0.1:7200/health','8800':'http://127.0.0.1:8800/v1/models'}
services = []
for pp in sorted(glob.glob(os.path.expanduser('~/Library/LaunchAgents/*.plist'))):
    label = os.path.basename(pp).replace('.plist','')
    if label.startswith('com.google.'): continue
    state, pid = 'DOWN', None
    for line in lc_out.splitlines():
        parts = line.split()
        if len(parts) >= 3 and parts[2] == label:
            if re.match(r'^\d+$', parts[0]): state, pid = 'UP', parts[0]
            elif parts[1] == '0': state = 'SCHED'
            else: state = 'CRASHED'
            break
    port = pid_port.get(pid) if pid else None
    mem = uptime = latency_ms = None
    if pid:
        r = subprocess.run(['ps','-o','rss=','-p',pid], capture_output=True, text=True)
        if r.stdout.strip(): mem = f"{int(r.stdout.strip())//1024}MB"
        r = subprocess.run(['ps','-o','etime=','-p',pid], capture_output=True, text=True)
        uptime = r.stdout.strip()
    if port:
        latency_ms = http_ms(HEALTH_URL.get(port, f'http://127.0.0.1:{port}/'), 0.3)
    services.append({'name':NAME_MAP.get(label,label),'label':label,'state':state,
                     'pid':pid,'port':port,'mem':mem,'uptime':uptime,'latency_ms':latency_ms})

# Ports
NOTE = {'6000':'SurrealDB','7010':'Executor','7200':'TTS','8011':'Substrate','8800':'LLM','11434':'Ollama',
        '3096':'Subagent','3097':'Dev-Brain','3098':'Anima','3099':'KotaDB'}
SKIP = {'ARDAgent','rapportd','ControlCe','mDNSResponder'}
ports = []
seen = set()
for line in lsof_out.splitlines()[1:]:
    parts = line.split()
    if len(parts) < 9: continue
    m = re.search(r':(\d+)$', parts[8])
    if not m: continue
    key = (parts[0], m.group(1))
    if key in seen or parts[0] in SKIP: continue
    seen.add(key)
    ports.append({'port':int(m.group(1)),'process':parts[0],'pid':parts[1],'note':NOTE.get(m.group(1),'')})

# MCP
mcp = []
cfg_path = os.path.expanduser('~/.claude.json')
KOTA_PORT = 3099
if os.path.exists(cfg_path):
    try:
        with open(cfg_path) as f:
            d = json.load(f)
    except Exception:
        d = {}
    for name, cfg in d.get('mcpServers',{}).items():
        t = cfg.get('type', cfg.get('transportType','?'))
        url = cfg.get('url','')
        port = None
        m = re.search(r':(\d+)', url)
        if m: port = m.group(1)
        entry = {'name':name,'type':t,'port':port}
        if port:
            ms = http_ms(f'http://127.0.0.1:{port}/', 0.5)
            entry.update({'state':'UP' if (ms is not None or sock_live(int(port))) else 'DOWN','latency_ms':ms})
        elif t == 'stdio':
            import shutil
            cmd = cfg.get('command','')
            entry.update({'state':'UP' if shutil.which(cmd) else 'MISSING','command':cmd})
            if name.lower().startswith('kotadb') or 'kotadb' in name.lower():
                entry['kota'] = {'port':KOTA_PORT,
                                 'state':'UP' if sock_live(KOTA_PORT) else 'DOWN'}
        mcp.append(entry)

# Ollama
ollama = []
try:
    r = subprocess.run(['ollama','list'], capture_output=True, text=True)
    ps = subprocess.run(['ollama','ps'], capture_output=True, text=True).stdout
    for line in r.stdout.splitlines()[1:]:
        if not line.strip(): continue
        parts = line.split()
        n = parts[0] if parts else ''
        sz = ' '.join(parts[2:4]) if len(parts)>3 else ''
        ollama.append({'name':n,'size':sz,'state':'loaded' if n and n in ps else 'idle'})
except: pass

# System
vm = subprocess.run(['vm_stat'], capture_output=True, text=True).stdout
act = wir = 0
for line in vm.splitlines():
    if 'Pages active' in line:
        m = re.search(r'(\d+)', line.split(':')[1]); act = int(m.group(1)) if m else 0
    if 'Pages wired down' in line:
        m = re.search(r'(\d+)', line.split(':')[1]); wir = int(m.group(1)) if m else 0
ram_gb = round((act+wir)*16384/1073741824, 1)
ram_tot = int(subprocess.run(['sysctl','-n','hw.memsize'], capture_output=True, text=True).stdout.strip())//1073741824
df = subprocess.run(['df','-h','/'], capture_output=True, text=True).stdout.splitlines()
df_p = df[1].split() if len(df)>1 else []
load = subprocess.run(['sysctl','-n','vm.loadavg'], capture_output=True, text=True).stdout.strip()

print(json.dumps({
    'version': 1,
    'host': socket.gethostname(),
    'timestamp': time.strftime('%Y-%m-%dT%H:%M:%S'),
    'services': services,
    'ports': sorted(ports, key=lambda x: x['port']),
    'mcp': mcp,
    'ollama': ollama,
    'system': {
        'ram_used_gb': ram_gb, 'ram_total_gb': ram_tot,
        'disk': f"{df_p[2]}/{df_p[1]} ({df_p[4]})" if len(df_p)>4 else '',
        'load_avg': load
    }
}, indent=2))
PYEOF
}

# ── SERVICE CONTROL (uses dev.services registry) ──────────────────────────────
_load_svcs()  { grep -v '^\s*#' "$SERVICES_FILE" | grep -v '^\s*$'; }
_get_row()    { _load_svcs | grep -i "^${1}|" | head -1; }

_svc_up() {
    local row=$(_get_row "$1")
    [[ -z "$row" ]] && printf "${RED}  unknown: %s${R}\n" "$1" && return 1
    local nm tp po st
    IFS='|' read -r nm tp po st _ _ <<< "$row"
    case "$tp" in
        launchd)   launchctl start "$st" 2>/dev/null ;;
        process)   eval "$st" &>/dev/null & ;;
        ephemeral) printf "${YLW}  %s is ephemeral${R}\n" "$nm"; return ;;
    esac
    # Wait for service to come up (poll for up to 5 seconds)
    local tries=0
    while (( tries < 10 )); do
        sleep 0.5
        local info=$(_svc_info "$nm" "$tp" "$po" "$st")
        [[ $(printf '%s' "$info" | cut -f1) == UP ]] && {
            printf "  ${GRN}●${R} ${WHT}%s${R} up\n" "$nm"
            return 0
        }
        (( tries++ ))
    done
    printf "  ${RED}✖${R} ${WHT}%s${R} failed\n" "$nm"
}

_svc_down() {
    local row=$(_get_row "$1")
    [[ -z "$row" ]] && printf "${RED}  unknown: %s${R}\n" "$1" && return 1
    local nm tp po st sp
    IFS='|' read -r nm tp po st sp _ <<< "$row"
    case "$tp" in
        launchd)   launchctl stop "$sp" 2>/dev/null ;;
        process)   eval "$sp" 2>/dev/null ;;
        ephemeral) printf "${YLW}  %s is ephemeral${R}\n" "$nm"; return ;;
    esac
    printf "  ${DIM}○${R} ${WHT}%s${R} stopped\n" "$nm"
}

_svc_info() {
    local nm="$1" tp="$2" po="$3" st="$4"
    local state=DOWN pid='' mem='-' up='-'
    case "$tp" in
        launchd)
            local row=$(launchctl list 2>/dev/null | awk -v l="$st" '$3==l{print $1,$2}' | head -1)
            local lpid="${row%% *}"
            [[ -n "$lpid" && "$lpid" =~ ^[0-9]+$ ]] && state=UP && pid="$lpid"
            ;;
        process|ephemeral)
            [[ "$po" != "none" ]] && _port_live "$po" && pid=$(_pid_on "$po") && state=UP
            ;;
    esac
    [[ "$po" != "none" && "$state" == UP ]] && ! _port_live "$po" && state=CRASHED
    [[ -n "$pid" && "$pid" =~ ^[0-9]+$ ]] && mem=$(_mem_mb "$pid") && up=$(_uptime_s "$pid")
    printf '%s\t%s\t%s\t%s' "$state" "${pid:--}" "$mem" "$up"
}

_all_up() {
    printf "\n${BOLD}  bringing everything up${R}\n\n"
    _load_svcs | while IFS='|' read -r nm tp po st sp hl; do
        [[ "$tp" == ephemeral ]] && continue
        local info=$(_svc_info "$nm" "$tp" "$po" "$st")
        if [[ $(printf '%s' "$info" | cut -f1) == UP ]]; then
            printf "  ${GRN}●${R} %-20s already up\n" "$nm"
        else
            printf "  ${YLW}↑${R} %-20s starting...\n" "$nm"
            case "$tp" in
                launchd) launchctl start "$st" 2>/dev/null ;;
                process) eval "$st" &>/dev/null & ;;
            esac
            # Poll for up to 5 seconds
            local tries=0 ok=0
            while (( tries < 10 )); do
                sleep 0.5
                info=$(_svc_info "$nm" "$tp" "$po" "$st")
                [[ $(printf '%s' "$info" | cut -f1) == UP ]] && { ok=1; break; }
                (( tries++ ))
            done
            printf "\033[1A\033[2K"
            (( ok )) \
                && printf "  ${GRN}●${R} %-20s up\n" "$nm" \
                || printf "  ${RED}✖${R} %-20s failed\n" "$nm"
        fi
    done
    printf '\n'
}

_all_down() {
    printf "\n${BOLD}  bringing everything down${R}\n\n"
    _load_svcs | while IFS='|' read -r nm tp po st sp hl; do
        [[ "$tp" == ephemeral ]] && continue
        printf "  ${DIM}○${R} %-20s stopping\n" "$nm"
        case "$tp" in
            launchd) launchctl stop "$sp" 2>/dev/null ;;
            process) eval "$sp" 2>/dev/null ;;
        esac
    done
    printf '\n'
}

# ── HELP ──────────────────────────────────────────────────────────────────────
_help() {
    local cols=$(tput cols 2>/dev/null || printf 80)
    printf "\n${BOLD}${WHT}  dev${R} — developer environment snapshot\n\n"

    printf "${BOLD}${CYN}  SNAPSHOT${R}\n"
    printf "${DIM}  %s${R}\n" "$(_hr $((cols-4)))"
    printf "  ${WHT}%-32s${R} %s\n" "dev"           "full snapshot (default)"
    printf "  ${WHT}%-32s${R} %s\n" "dev status"    "alias for dev"
    printf "  ${WHT}%-32s${R} %s\n" "dev watch [N]" "auto-refresh every N seconds (default: 5)"
    printf "  ${WHT}%-32s${R} %s\n" "dev --json"    "JSON snapshot (schema v1) for agents / scripts"
    printf '\n'

    printf "${BOLD}${CYN}  CONTROL${R}\n"
    printf "${DIM}  %s${R}\n" "$(_hr $((cols-4)))"
    printf "  ${WHT}%-32s${R} %s\n" "dev up"              "start all persistent services"
    printf "  ${WHT}%-32s${R} %s\n" "dev up <name>"       "start one service"
    printf "  ${WHT}%-32s${R} %s\n" "dev down"            "stop all persistent services"
    printf "  ${WHT}%-32s${R} %s\n" "dev down <name>"     "stop one service"
    printf "  ${WHT}%-32s${R} %s\n" "dev restart"         "restart all persistent services"
    printf "  ${WHT}%-32s${R} %s\n" "dev restart <name>"  "restart one service"
    printf "  ${WHT}%-32s${R} %s\n" "dev logs <name>"     "tail log file for a launchd service"
    printf '\n'

    printf "${BOLD}${CYN}  PANELS${R}\n"
    printf "${DIM}  %s${R}\n" "$(_hr $((cols-4)))"
    printf "  ${DIM}%-16s${R}  %s\n" "CORE SERVICES" "LaunchAgents — state · port · RTT · mem · uptime"
    printf "  ${DIM}%-16s${R}  %s\n" "OPEN PORTS"   "all TCP listeners (system noise filtered)"
    printf "  ${DIM}%-16s${R}  %s\n" "AGENT IO"     "~/.claude.json — MCP servers for agents"
    printf "  ${DIM}%-16s${R}  %s\n" "LOCAL MODELS" "Ollama · Whisper (Tuna STT) · Apple on-device"
    printf "  ${DIM}%-16s${R}  %s\n" "SYSTEM HEALTH" "RAM · Disk · Load"
    printf '\n'

    printf "${BOLD}${CYN}  REGISTRY${R}  ${DIM}(for up/down/restart)${R}\n"
    printf "${DIM}  %s${R}\n" "$(_hr $((cols-4)))"
    printf "  ${DIM}%s${R}\n\n" "$SERVICES_FILE"
}

# ── ENTRY ─────────────────────────────────────────────────────────────────────
case "${1:-}" in
    ''|status)
        _status ;;
    watch)
        _watch "${2:-5}" ;;
    --json)
        _json_output ;;
    logs)
        _logs "${2:-}" ;;
    up)
        [[ -n "${2:-}" ]] && _svc_up "$2" || _all_up ;;
    down)
        [[ -n "${2:-}" ]] && _svc_down "$2" || _all_down ;;
    restart)
        if [[ -n "${2:-}" ]]; then
            _svc_down "$2"; sleep 2; _svc_up "$2"
        else
            _all_down; sleep 2; _all_up
        fi ;;
    help|-h|--h|-help|--help)
        _help ;;
    *)
        printf "${RED}  unknown: %s${R}\n" "$1"
        _help ;;
esac
