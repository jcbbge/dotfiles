<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.belvedere.tts-server</string>
    
    <key>ProgramArguments</key>
    <array>
        <string>/Users/jrg/tts/.venv/bin/python3</string>
        <string>/Users/jrg/belvedere/services/tts-server.py</string>
    </array>
    
    <key>WorkingDirectory</key>
    <string>/Users/jrg/belvedere/services</string>
    
