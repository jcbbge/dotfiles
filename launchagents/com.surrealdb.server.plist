<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.surrealdb.server</string>
    <key>ProgramArguments</key>
    <array>
        <string>/opt/homebrew/bin/surreal</string>
        <string>start</string>
        <string>--log</string>
        <string>info</string>
        <string>--username</string>
        <string>root</string>
        <string>--password</string>
        <string>surreal</string>
        <string>--bind</string>
        <string>127.0.0.1:6000</string>
        <string>rocksdb:///Users/jrg/surreal/data</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>WorkingDirectory</key>
    <string>/Users/jrg/surreal</string>
    <key>StandardOutPath</key>
    <string>/Users/jrg/surreal/logs/surreal.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/jrg/surreal/logs/surreal-error.log</string>
</dict>
</plist>
